{
  "name": "build-tools-boilerplate",
  "version": "2.0.0",
  "description": "Simple recipes for building and compiling with the CLI.",
  "author": {
    "name": "Legit agency",
    "url": "https://legitagency.nl"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "http://github.com/cferdinandi/build-tools-boilerplate"
  },
  "scripts": {
    "clean": "recursive-delete 'dist'",
    "js": "rollup --config",
    "js:watch": "rollup --config --watch",
    "css": "node sass.js --prod",
    "css:watch": "chokidar './src/**/*.scss' -c 'node sass.js --dev'",
    "svg": "svgo -f src/svg dist/svg -r",
    "img": "imagemin src/img/* --out-dir=dist/img --plugin=pngquant --plugin=mozjpeg --plugin=pngcrush --plugin=zopfli",
    "copy": "recursive-copy 'src/copy' 'dist'",
    "build:assets": "npm-run-all -p svg img copy",
    "build": "npm-run-all -s clean -p css js",
    "build:full": "npm-run-all -s clean -p css js svg img copy",
    "watch": "npm-run-all -p css:watch js:watch",
    "server-start": "browser-sync start --files 'dist' --server 'dist'",
    "server": "npm-run-all -p watch server-start"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.20",
    "browser-sync": "^3.0.3",
    "chokidar-cli": "^2.1.0",
    "dir-archiver": "^2.1.0",
    "imagemin-cli": "^8.0.0",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngcrush": "^5.1.0",
    "imagemin-pngquant": "^10.0.0",
    "imagemin-zopfli": "^5.1.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "recursive-fs": "^2.1.0",
    "rollup": "^2.6.1",
    "rollup-plugin-terser": "^7.0.2",
    "rtlcss": "^4.3.0",
    "sass": "1.32.0",
    "svgo": "^3.3.2"
  },
  "browserslist": [
    "last 2 versions",
    "not dead",
    "Firefox ESR"
  ],
  "rtlcssConfig": {
    "options": {
      "autoRename": false,
      "autoRenameStrict": false,
      "blacklist": {},
      "clean": true,
      "greedy": false,
      "processUrls": false,
      "stringMap": []
    },
    "plugins": [],
    "map": false
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.7"
  }
}
